# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual envs
.venv/
venv/
env/

# Secrets — NEVER commit these
.env
.env.*
secrets.toml
.streamlit/secrets.toml

# Local dry-run / scratch output
*.log
dryrun_*.json

# Append-only audit logs — written every cycle, never read back by the engine
# or dashboard (state.json + docs/data.json carry everything the system uses).
# Kept local for offline analysis; not committed, to keep the repo/.git small.
data/observations.jsonl
data/leaderboard.jsonl

# Dashboard payload now served from Supabase Storage, not committed per cycle.
# The last committed copy stays as a fallback; the poller writes a fresh local
# copy each run (gitignored) and uploads it to Supabase.
docs/data.json

# OS / editor
.DS_Store

# Local dev-preview config (Claude Code launch.json) — environment-specific
.claude/
.idea/
.vscode/

# Fast-mark price overlay — published to Supabase Storage by the Worker, not committed.
docs/marks.json
